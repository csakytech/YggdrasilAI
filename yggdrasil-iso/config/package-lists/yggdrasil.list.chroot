# --- GPU support (hardware-agnostic) ---
# We do NOT bake the proprietary NVIDIA driver. The open in-kernel drivers (nouveau/amdgpu/i915)
# already give a working desktop on any GPU. First-boot detects the vendor and installs the right
# proprietary driver on the actual machine (NVIDIA -> nvidia-driver), so the ISO boots everywhere
# and the build needs no DKMS compile. We keep general firmware + headers + dkms so that first-boot
# NVIDIA install is self-contained and the headers match the baked kernel.
firmware-misc-nonfree
linux-headers-amd64
dkms

# --- Python / app runtime ---
python3
python3-venv
python3-pip
pipx
python3-dev
build-essential

# --- Audio (voice I/O) ---
portaudio19-dev
libasound2-dev
alsa-utils
pipewire
pipewire-audio

# --- Ollama prereqs + tooling ---
curl
ca-certificates
jq
pciutils
git

# --- Desktop control + GTK UIs + office automation (Yggdrasil agents) ---
# NOTE: live-build only strips whole-line comments — never put a # after a package name.
# window activation/close, keystroke injection, focused-window class
wmctrl
xdotool
x11-utils
# PyGObject + GTK3 typelib for the dashboard / HUD / chat window
python3-gi
gir1.2-gtk-3.0
# UNO bridge for the LibreOffice (Writer) deep-adapter agent
python3-uno
