#!/bin/sh
# Bake the Yggdrasil app into the image: clone the public repo, build a system venv with the full
# voice stack, and fetch the Piper voice. Runs in the live-build chroot (needs network). The
# launchers in /usr/local/bin point at /opt/yggdrasil/venv, so it works for any installed user.
set -e
echo "I: yggdrasil — installing app into /opt/yggdrasil"

rm -rf /opt/yggdrasil
git clone --depth 1 https://github.com/csakytech/YggdrasilAI.git /opt/yggdrasil

# System venv. --system-site-packages so PyGObject (gi) from the distro is importable for the GTK UIs.
python3 -m venv --system-site-packages /opt/yggdrasil/venv
/opt/yggdrasil/venv/bin/pip install --no-cache-dir -U pip wheel
/opt/yggdrasil/venv/bin/pip install --no-cache-dir -e "/opt/yggdrasil/yggdrasil[voice]"
# Note: STT runs on CPU in the image (hardware-agnostic). The GPU Whisper CUDA libs are NVIDIA-only
# and large, so they're not baked in; a future first-boot step can add them on NVIDIA machines.

# Piper voice (en_US lessac, medium).
mkdir -p /opt/yggdrasil/voices
V="https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium"
curl -fsSL -o /opt/yggdrasil/voices/en_US-lessac-medium.onnx      "$V/en_US-lessac-medium.onnx"
curl -fsSL -o /opt/yggdrasil/voices/en_US-lessac-medium.onnx.json "$V/en_US-lessac-medium.onnx.json"

chmod -R a+rX /opt/yggdrasil
mkdir -p /var/lib/yggdrasil
echo "I: yggdrasil — app install complete ($(/opt/yggdrasil/venv/bin/python --version))"
